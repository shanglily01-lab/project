# Copy to backend/.env and fill in. Never commit the real .env.

# ─── Database (local dev: install MySQL 8+ and create syphonix DB) ─
DATABASE_URL=mysql://syphonix:syphonix@localhost:3306/syphonix

# ─── OpenProject ──────────────────────────────────────
# Base URL of your OpenProject instance (no trailing slash) + an API token.
OP_TARGET=https://openproject.example.com
OP_BASE_URL=/api/v3
OP_TOKEN=

# Restrict roster seeding to one email domain (optional; blank = no filter).
COMPANY_EMAIL_DOMAIN=

# ─── AWS CodeCommit (read-only) ───────────────────────
# Static keys for a read-only IAM user. Without these, the AWS default
# credential chain is used (e.g. an SSO profile).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Server ───────────────────────────────────────────
PORT=3060
POLL_INTERVAL_MS=60000
LOG_LEVEL=info
