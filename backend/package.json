{
  "name": "projectx-data-core-backend",
  "version": "0.1.0",
  "description": "ProjectX Data Core — project-tracking data acquisition (OpenProject + CodeCommit) and read API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "tsx watch src/index.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "op:check": "tsx src/scripts/op-check.ts",
    "op:users": "tsx src/scripts/op-users.ts",
    "op:ingest": "tsx src/scripts/op-ingest.ts",
    "code:ingest": "tsx src/scripts/code-ingest.ts",
    "repos:list": "tsx src/scripts/repos-list.ts",
    "seed:op": "tsx src/scripts/seed-from-op.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-codecommit": "^3.1058.0",
    "@aws-sdk/credential-providers": "^3.1058.0",
    "@fastify/cors": "^10.0.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "mysql2": "^3.14.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0"
  }
}
